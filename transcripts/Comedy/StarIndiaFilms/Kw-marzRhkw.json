    "duration": 4.021
  },
  {
    "text": "करिए",
    "start": 1720.08,
    "duration": 4.82
  },
  {
    "text": "जो आप लोग क्या कर सकते हैं",
    "start": 1721.58,
    "duration": 3.32
  },
  {
    "text": "[संगीत]",
    "start": 1754.19,
    "duration": 3.039
  },
  {
    "text": "ऐसा जहां",
    "start": 1757.58,
    "duration": 2.78
  },
  {
    "text": "हमेशा पॉजिटिव सोच लेता की हर चीज अमर",
    "start": 1761.799,
    "duration": 5.341
  },
  {
    "text": "पॉजिटिव",
    "start": 1764.899,
    "duration": 2.241
  },
  {
    "text": "[संगीत]",
    "start": 1770.99,
    "duration": 4.01
  },
  {
    "text": "कर रहा है तो उसको",
    "start": 1772.299,
    "duration": 6.041
  },
  {
    "text": "और बेहतर बनाने की कोशिश करिए उसको सराहना",
    "start": 1775.0,
    "duration": 6.64
  },
  {
    "text": "दीजिए उसको sarahiye उसकी तारीफ करिए ताकि",
    "start": 1778.34,
    "duration": 6.36
  },
  {
    "text": "वह और बेहतर करें ठीक है और आपसे नहीं",
    "start": 1781.64,
    "duration": 5.46
  },
  {
    "text": "होता है आपका आपके जुबान में बेहतर शब्द",
    "start": 1784.7,
    "duration": 5.24
  },
  {
    "text": "नहीं आते हैं तो",
    "start": 1787.1,
    "duration": 2.84
  },
  {
    "text": "ताकि दुनिया का आईना बन सके हम तो कोशिश",
    "start": 1809.559,
    "duration": 5.381
  },
  {
    "text": "करिए कोई भी अगर यहां तक आता है ना तब",
    "start": 1813.14,
    "duration": 3.96
  },
  {
    "text": "विदाउट मेहनत नहीं आता भाई तू कहने का",
    "start": 1814.94,
    "duration": 3.54
  },
  {
    "text": "पहुंच जाता",
    "start": 1817.1,
    "duration": 4.38
  },
  {
    "text": "है",
    "start": 1818.48,
    "duration": 3.0
  },
  {
    "text": "आज हमारे बारे में चाहिए और के बारे में",
    "start": 1822.559,
    "duration": 4.681
  },
  {
    "text": "बोलकर कमाते हैं तो कमाई है बेहतर है",
    "start": 1824.6,
    "duration": 5.24
  },
  {
    "text": "लेकिन बुरा बोल के ना अच्छा बोल के ठीक है",
    "start": 1827.24,
    "duration": 6.059
  },
  {
    "text": "लवी ऑल थैंक यू सो मच हसीना को प्यार आप",
    "start": 1829.84,
    "duration": 5.74
  },
  {
    "text": "जो दे रहे हैं और आप कोशिश करते रहिए",
    "start": 1833.299,
    "duration": 4.201
  },
  {
    "text": "जितना घर सकते हैं आप गर्ने की कोशिश करिए",
    "start": 1835.58,
    "duration": 4.74
  },
  {
    "text": "हम निकलने की कोशिश करते हैं थैंक यू लव",
    "start": 1837.5,
    "duration": 5.22
  },
  {
    "text": "यू ऑल दिल से प्रणाम आप लोग अपना ख्याल",
    "start": 1840.32,
    "duration": 6.06
  },
  {
    "text": "रखिए और लंदन में अभी 7:00 बज रहा है",
    "start": 1842.72,
    "duration": 6.179
  },
  {
    "text": "तो अभी हम उठे हैं",
    "start": 1846.38,
    "duration": 4.94
  },
  {
    "text": "थैंक यू",
    "start": 1848.899,
    "duration": 2.421
  },
  {
    "text": "कॉन्फिडेंस में अपना जनता के प्रति अपना",
    "start": 1854.98,
    "duration": 7.439
  },
  {
    "text": "जनता के प्यार खाती जॉन भी वही हम करो",
    "start": 1857.539,
    "duration": 4.88
  },
  {
    "text": "लगे दिल नवा ए हसीना",
