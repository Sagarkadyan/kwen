    "duration": 2.78
  },
  {
    "text": "[संगीत]",
    "start": 1594.89,
    "duration": 3.089
  },
  {
    "text": "भारत बखानी",
    "start": 1602.84,
    "duration": 3.26
  },
  {
    "text": "उत्तर",
    "start": 1618.64,
    "duration": 3.0
  },
  {
    "text": "गाना उतर जाएगी",
    "start": 1622.419,
    "duration": 3.36
  },
  {
    "text": "[संगीत]",
    "start": 1629.22,
    "duration": 3.049
  },
  {
    "text": "अगर तुम लोग बनावट नहीं खत्म मत कर लो",
