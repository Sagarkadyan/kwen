    "duration": 4.16
  },
  {
    "text": "21 तारीख",
    "start": 1457.039,
    "duration": 2.961
  },
  {
    "text": "के पीछे",
    "start": 1470.32,
    "duration": 4.56
  },
  {
    "text": "[संगीत]",
    "start": 1471.83,
    "duration": 3.05
  },
  {
    "text": "हान लेकिन आज थोड़ा सा प्रॉब्लम",
    "start": 1500.299,
    "duration": 3.561
  },
  {
    "text": "जाको रखे सैयां मार सके ना कोई",
    "start": 1531.799,
    "duration": 6.441
  },
  {
    "text": "ठीक बना",
    "start": 1535.52,
    "duration": 2.72
  },
  {
    "text": "तो दिखाता नहीं की कब तक हसीना",
