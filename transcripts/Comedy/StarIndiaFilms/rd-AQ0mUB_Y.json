[
  {
    "text": "बंगलिया से दवाया",
    "start": 0.04,
    "duration": 6.64
  },
  {
    "text": "बाला कि आ सुहाग वाली",
    "start": 1.919,
    "duration": 4.761
  },
  {
    "text": "दतिया त लोग कहा",
    "start": 7.08,
    "duration": 3.599
  },
  {
    "text": "बड़ कतना मोबाइल में रहे र में र मे फोन",
    "start": 11.04,
    "duration": 6.719
  },
  {
    "text": "करले",
    "start": 14.92,
    "duration": 2.839
  },
  {
    "text": "हा हम हमरे मेरा के ठीक",
    "start": 18.4,
    "duration": 6.67
  },
  {
    "text": "बा फोन ना कर बचारी",
    "start": 22.0,
    "duration": 6.149
  },
  {
    "text": "[संगीत]",
    "start": 25.07,
    "duration": 3.079
  },
  {
    "text": "कि आई सुहाग वाली",
    "start": 32.559,
    "duration": 7.961
  },
  {
    "text": "रतिया की धक धक करी मोरा",
    "start": 35.8,
    "duration": 9.84
  },
  {
    "text": "छतिया कीले लागी पलंग के",
    "start": 40.52,
    "duration": 5.12
  },
  {
    "text": "पल लहा बंगलिया से दवईया",
    "start": 46.8,
    "duration": 6.84
  },
  {
    "text": "[संगीत]",
    "start": 52.4,
    "duration": 3.4
  },
  {
    "text": "आ",
    "start": 53.64,
    "duration": 5.52
  },
  {
    "text": "गया लोड हो रहा है दो चार पांच गाने लोड",
    "start": 55.8,
    "duration": 7.679
  },
  {
    "text": "करके रखा करि आपके ही काम आएंगे",
    "start": 59.16,
    "duration": 6.36
  },
  {
    "text": "लो अच्छा",
    "start": 63.479,
    "duration": 5.041
  },
  {
    "text": "पन",
    "start": 65.52,
    "duration": 3.0
  },
  {
    "text": "तो इसमें",
    "start": 68.88,
    "duration": 9.0
  },
  {
    "text": "नहीं हां व हा तो शुभी जी है आइए",
    "start": 71.119,
    "duration": 11.121
  },
  {
    "text": "आ य शभ जी बड़ी प्यारी एक्टर है और हमारे",
    "start": 77.88,
    "duration": 8.44
  },
  {
    "text": "सबकी सबकी हमारे बिहार रूपी से है नहीं यह",
    "start": 82.24,
    "duration": 6.199
  },
  {
    "text": "जयपुर से है उसके बावजूद भी हमारे बिहार",
    "start": 86.32,
    "duration": 4.96
  },
  {
    "text": "रूपी के लोगों के प्यार में है और लोगों",
    "start": 88.439,
    "duration": 6.161
  },
  {
    "text": "ने बड़ा प्यार दिया इनको और ये मेरे",
    "start": 91.28,
    "duration": 5.92
  },
  {
    "text": "इंडस्ट्री के बहुत बड़ी आर्टिस्ट है बहुत",
    "start": 94.6,
    "duration": 6.479
  },
  {
    "text": "बड़ी सुपर स्टार है और भगवान कहे कि हमेशा",
    "start": 97.2,
    "duration": 6.32
  },
  {
    "text": "ऐसे ही जिस तरह शरीर बढ़ रहा है उसी तरह",
    "start": 101.079,
    "duration": 4.72
  },
  {
    "text": "यह भी",
    "start": 103.52,
    "duration": 2.279
  },
  {
    "text": "बढ़े शरीर हमारे लिए हमारा शरीर हमारा कभी",
    "start": 106.92,
    "duration": 7.199
  },
  {
    "text": "होता ही नहीं क्योंकि हम अपने लिए कभी बने",
    "start": 110.719,
    "duration": 6.921
  },
  {
    "text": "ही नहीं हम तो एक ऐसे वस्तु है जो हर आदमी",
    "start": 114.119,
    "duration": 8.121
  },
  {
    "text": "की जरूरत है और हम यही करते हैं कि हमारी",
    "start": 117.64,
    "duration": 7.28
  },
  {
    "text": "अपनी जरूरत पूरी हो या ना हो हम आप सबकी",
    "start": 122.24,
    "duration": 5.28
  },
  {
    "text": "जरूरत को हमेशा पूरी करते रहे चाहे वो",
    "start": 124.92,
    "duration": 5.36
  },
  {
    "text": "सिनेमा के माध्यम से हो एक मेरा बहुत बड़ा",
    "start": 127.52,
    "duration": 7.02
  },
  {
    "text": "गाना इधर चुमा चुमा दे",
    "start": 130.28,
    "duration": 5.56
  },
  {
    "text": "[संगीत]",
    "start": 134.54,
    "duration": 4.82
  },
  {
    "text": "दे जोक वो भी आर्टिस्ट हमारे यहां की नहीं",
    "start": 135.84,
    "duration": 6.96
  },
  {
    "text": "है व इंदौर से है जिनका नाम आकांक्षा पुरी",
    "start": 139.36,
    "duration": 6.159
  },
  {
    "text": "है वो इंदौर से उसके बावजूद भी लोगों ने",
    "start": 142.8,
    "duration": 5.12
  },
  {
    "text": "इतना प्यार दिया तो हमारे बिहार रूपी की",
    "start": 145.519,
    "duration": 5.401
  },
  {
    "text": "बहुत कमी ऐसी लड़किया है बट सब जितने भी",
    "start": 147.92,
    "duration": 5.48
  },
  {
    "text": "हमारे भोजपुरी को आज प्रेजेंट करती हैं",
    "start": 150.92,
    "duration": 5.2
  },
  {
    "text": "लड़कियां सब कहीं ना कहीं बाहर से ही है",
    "start": 153.4,
    "duration": 6.0
  },
  {
    "text": "लेकिन इन लोगों का प्यार ही आज भोजपुरी को",
    "start": 156.12,
    "duration": 5.6
  },
  {
    "text": "भी बड़ा कर रहा है इनका अपना योगदान है एक",
    "start": 159.4,
    "duration": 4.93
  },
  {
    "text": "भोजपुरी समाज के लिए हो गया",
    "start": 161.72,
    "duration": 4.04
  },
  {
    "text": "[संगीत]",
    "start": 164.33,
    "duration": 6.15
  },
  {
    "text": "लोड हो रहा है करा",
    "start": 165.76,
    "duration": 8.479
  },
  {
    "text": "दीजिए और आज इस जगह पर हम आए हैं हमारे",
    "start": 170.48,
    "duration": 7.2
  },
  {
    "text": "परिवार में आई है डीजीएस परिवार का एक मैं",
    "start": 174.239,
    "duration": 7.64
  },
  {
    "text": "भी सबसे छोटा बेटा हूं और आज",
    "start": 177.68,
    "duration": 8.08
  },
  {
    "text": "हमारे भतीजे के तिलक में आई है तो मेरे",
    "start": 181.879,
    "duration": 6.121
  },
  {
    "text": "तरफ से भतीजा लाक तो है नहीं वो मेरे भाई",
    "start": 185.76,
    "duration": 5.92
  },
  {
    "text": "लायक है बट अब क्या करें ईश्वर भैया को",
    "start": 188.0,
    "duration": 5.68
  },
  {
    "text": "बड़ा भाई मानता हूं राजू भैया को मानता",
    "start": 191.68,
    "duration": 5.639
  },
  {
    "text": "हूं उस हिसाब से मैं बोल दिया नहीं तो",
    "start": 193.68,
    "duration": 6.839
  },
  {
    "text": "मेरा भी उम्र कुछ ज्यादा नहीं",
    "start": 197.319,
    "duration": 6.441
  },
  {
    "text": "है 36",
    "start": 200.519,
    "duration": 7.761
  },
  {
    "text": "साल देखि हमार पंडित जी हम जन्म कुंडली",
    "start": 203.76,
    "duration": 6.86
  },
  {
    "text": "बना र",
    "start": 208.28,
    "duration": 3.879
  },
  {
    "text": "[प्रशंसा]",
    "start": 210.62,
    "duration": 7.86
  },
  {
    "text": "अरे का क जा हम 1989 के पैदा अभी 32 साल",
    "start": 212.159,
    "duration": 10.241
  },
  {
    "text": "हमारे जवे भाई तो से",
    "start": 218.48,
    "duration": 7.66
  },
  {
    "text": "छो हो गया आइए बजाइए",
    "start": 222.4,
    "duration": 11.31
  },
  {
    "text": "[संगीत]",
    "start": 226.14,
    "duration": 7.57
  }
